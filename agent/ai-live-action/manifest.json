{
  "id": "ai-live-action-first-frame",
  "version": "0.1.0",
  "title": "AI+实拍首帧多 Agent 工作流",
  "status": "prompt-only",
  "scope": "single-frame-first-frame-redraw",
  "description": "独立的 AI+实拍首帧重构与转绘 Agent 资源包，不接入 /chat，不混入 script-agent。",
  "agents": [
    {
      "id": "main-orchestrator",
      "name": "AI+实拍流程主理人",
      "file": "agents/main-orchestrator.md",
      "responsibility": "流程调度、素材检查、素材索引、角色/道具绑定、调用顺序和最终结果汇总"
    },
    {
      "id": "shot-reconstruction-director",
      "name": "镜头重构师",
      "file": "agents/shot-reconstruction-director.md",
      "responsibility": "分析转绘后的首帧应该长什么样，输出结构化镜头重构方案"
    },
    {
      "id": "first-frame-redraw-artist",
      "name": "首帧转绘师",
      "file": "agents/first-frame-redraw-artist.md",
      "responsibility": "把镜头重构结果转成可执行生图规格"
    }
  ],
  "schemas": {
    "assetBundle": "schemas/asset-bundle.schema.json",
    "reconstructionOutput": "schemas/reconstruction-output.schema.json",
    "redrawOutput": "schemas/redraw-output.schema.json"
  },
  "primaryInputs": [
    "sceneGridImage",
    "markedSceneGridImage",
    "sourceFirstFrameImage",
    "characters",
    "props",
    "userIntentOptional"
  ],
  "primaryOutputs": [
    "assetReview",
    "reconstructionOutput",
    "redrawOutput"
  ],
  "boundaries": [
    "No /chat integration",
    "No script-agent prompt-loader integration",
    "No page or API routes in this version",
    "No image generation call in this version",
    "No database or storage migration in this version"
  ]
}
