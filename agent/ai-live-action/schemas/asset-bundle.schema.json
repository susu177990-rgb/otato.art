{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://otato.art/schemas/ai-live-action/asset-bundle.schema.json",
  "title": "AI+实拍素材包",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sceneGridImage",
    "sourceFirstFrameImage",
    "characters",
    "props"
  ],
  "properties": {
    "sceneGridImage": {
      "$ref": "#/$defs/assetRef",
      "description": "目标场景资产宫格图"
    },
    "markedSceneGridImage": {
      "$ref": "#/$defs/assetRef",
      "description": "带位置/角色标识的目标场景资产宫格图"
    },
    "sourceFirstFrameImage": {
      "$ref": "#/$defs/assetRef",
      "description": "原实拍视频片段首帧图"
    },
    "characters": {
      "type": "array",
      "description": "目标角色图列表",
      "items": {
        "$ref": "#/$defs/characterAsset"
      },
      "default": []
    },
    "props": {
      "type": "array",
      "description": "目标道具图列表",
      "items": {
        "$ref": "#/$defs/propAsset"
      },
      "default": []
    },
    "userIntent": {
      "type": "string",
      "description": "用户文字输入意图/注意事项；可为空，为空时由 Agent 根据图片自行分析"
    },
    "notes": {
      "type": "string",
      "description": "额外制作备注"
    }
  },
  "$defs": {
    "assetRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "kind"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "scene-grid",
            "marked-scene-grid",
            "source-first-frame",
            "character",
            "prop"
          ]
        },
        "url": {
          "type": "string"
        },
        "storagePath": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "characterAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "image"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "image": {
          "$ref": "#/$defs/assetRef"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "propAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "image"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "image": {
          "$ref": "#/$defs/assetRef"
        },
        "boundCharacterName": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
