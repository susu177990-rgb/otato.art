{
  "name": "otato-art",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "otato.art — content creation and visual production workspace",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "next dev -p 4000 --webpack",
    "dev:web:turbopack": "next dev -p 4000",
    "dev:web:webpack": "next dev -p 4000 --webpack",
    "build": "next build",
    "postbuild": "node scripts/copy-repo-assets-to-standalone.mjs",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "test": "vitest run",
    "e2e:smoke": "node scripts/e2e-regression.mjs",
    "smoke:extract-stage5": "npx tsx lib/artifact-extract.stage5.smoke.ts",
    "smoke:canvas-connections": "npx tsx lib/canvas/connection-rules.smoke.ts",
    "smoke:canvas-board-store": "npx tsx lib/canvas/board-store.smoke.ts",
    "smoke:video-workspace": "vitest run lib/video-workspace.smoke.test.ts",
    "smoke:me": "npx tsx lib/me.smoke.ts",
    "smoke:video-generation": "vitest run lib/video-generation-service.smoke.test.ts",
    "smoke:asset-mentions": "npx tsx lib/asset-mentions.smoke.ts",
    "smoke:legacy-baseline": "npx tsx scripts/check-script-agent-legacy-baseline.ts",
    "smoke:direction-shadow": "npx tsx scripts/check-script-agent-direction-shadow.ts",
    "smoke:prompt-modular": "npx tsx scripts/check-script-agent-prompt-modular.ts",
    "smoke:prompt-parity": "npx tsx scripts/check-script-agent-prompt-parity.ts",
    "smoke:prompt-fixtures": "npx tsx scripts/check-script-agent-prompt-fixtures.ts",
    "smoke:bl-modular-parity": "npx tsx scripts/check-script-agent-bl-modular-parity.ts",
    "smoke:legacy-archive": "npx tsx scripts/check-script-agent-legacy-archive.ts",
    "report:script-agent-rule-diff": "npx tsx scripts/report-script-agent-rule-diff.ts",
    "report:script-agent-migration": "npx tsx scripts/report-script-agent-migration-readiness.ts",
    "credits:crun-prices": "npx tsx scripts/generate-crun-credit-prices.ts",
    "migrate:supabase": "npx tsx scripts/migrate-local-data-to-supabase.ts",
    "db:push": "npx tsx scripts/push-supabase-migrations.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@lexical/history": "^0.45.0",
    "@lexical/plain-text": "^0.45.0",
    "@lexical/react": "^0.45.0",
    "@lexical/utils": "^0.45.0",
    "@rjsf/core": "^6.5.3",
    "@rjsf/utils": "^6.5.3",
    "@rjsf/validator-ajv8": "^6.5.3",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "ajv": "^8.20.0",
    "jszip": "^3.10.1",
    "lexical": "^0.45.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.7",
    "next": "16.2.9",
    "pdf-parse": "^1.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "pg": "^8.21.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "unrs-resolver@1.11.1": true
  }
}
