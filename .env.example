# Supabase（Zeabur / 本地 .env.local，勿提交真实密钥）
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret  # 仅本地迁移脚本需要；封面上传等 Web 功能不需要

# 生产部署域名（用于 Supabase 注册邮件回调；不要带末尾斜杠）
APP_ORIGIN=https://your-domain.example.com

# Stripe 一次性积分充值
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# 定时维护任务：POST /api/cron/credits/maintenance
CRON_SECRET=replace_with_a_long_random_secret

# 可选：npm run db:push 用（二选一）
# SUPABASE_ACCESS_TOKEN=从 https://supabase.com/dashboard/account/tokens 创建
# SUPABASE_DB_PASSWORD=Project Settings → Database 里的数据库密码

# 一次性迁移本地 JSON 到 Supabase（scripts/migrate-local-data-to-supabase.ts）
# 需先注册账号，再：npx tsx scripts/migrate-local-data-to-supabase.ts --owner-email=you@example.com

# 端到端回归 smoke（npm run e2e:smoke）
# E2E_BASE_URL=http://localhost:4000
# E2E_EMAIL=you@example.com
# E2E_PASSWORD=your-password
# E2E_ALLOW_AUTH_SKIP=1

# Baked defaults（可选，不设则回退到空字符串，通过 Supabase store 读取 API Key）
# NEXT_PUBLIC_BAKED_API_URL=https://your-gateway/v1/chat/completions
# NEXT_PUBLIC_BAKED_API_KEY=sk-your-key
# NEXT_PUBLIC_BAKED_MODEL=gpt-4o
